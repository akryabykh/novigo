# Novigo — Supabase environment
# Copy to .env and fill with your project's values (Project Settings → API).
# Both vars must be EXPO_PUBLIC_* so they are inlined into the web/native bundle.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
